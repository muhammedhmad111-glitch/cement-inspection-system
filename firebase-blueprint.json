{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Store products",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string", "enum": ["cod", "online"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "status", "shippingAddress", "paymentMethod", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product reviews",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "userName", "rating", "comment", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "name", "slug", "image"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Store settings",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "storeDescription": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "currency": { "type": "string" },
        "shippingFee": { "type": "number" },
        "freeShippingThreshold": { "type": "number" },
        "socialLinks": { "type": "object" }
      }
    },
    "Banner": {
      "title": "Banner",
      "description": "Homepage banners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "buttonText": { "type": "string" },
        "isActive": { "type": "boolean" },
        "type": { "type": "string", "enum": ["hero", "promo"] }
      },
      "required": ["id", "title", "image", "isActive", "type"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer testimonials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "text", "isActive"]
    },
    "HomepageSettings": {
      "title": "Homepage Settings",
      "description": "Configuration for homepage sections",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "featuredTitle": { "type": "string" },
        "featuredSubtitle": { "type": "string" },
        "bestSellersTitle": { "type": "string" },
        "bestSellersSubtitle": { "type": "string" },
        "testimonialsTitle": { "type": "string" },
        "showNewsletter": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Store settings"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Homepage banners"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Customer testimonials"
    },
    "/homepage_settings/{settingId}": {
      "schema": "HomepageSettings",
      "description": "Homepage configuration"
    }
  }
}
